<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         id="WebApp_ID" version="3.1">

    <display-name>Freelite</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- A - 用户模块 -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.freelite.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.freelite.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- B - 项目模块 -->
    <servlet>
        <servlet-name>ProjectListServlet</servlet-name>
        <servlet-class>com.freelite.servlet.ProjectListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProjectListServlet</servlet-name>
        <url-pattern>/projects</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PostProjectServlet</servlet-name>
        <servlet-class>com.freelite.servlet.PostProjectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PostProjectServlet</servlet-name>
        <url-pattern>/project/post</url-pattern>
    </servlet-mapping>

    <!-- C - 竞标模块 -->
    <servlet>
        <servlet-name>PlaceBidServlet</servlet-name>
        <servlet-class>com.freelite.servlet.PlaceBidServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PlaceBidServlet</servlet-name>
        <url-pattern>/bid/place</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BidListServlet</servlet-name>
        <servlet-class>com.freelite.servlet.BidListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BidListServlet</servlet-name>
        <url-pattern>/bids/*</url-pattern>
    </servlet-mapping>

    <!-- D - 订单/评价 -->
    <servlet>
        <servlet-name>OrderListServlet</servlet-name>
        <servlet-class>com.freelite.servlet.OrderListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderListServlet</servlet-name>
        <url-pattern>/orders</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReviewServlet</servlet-name>
        <servlet-class>com.freelite.servlet.ReviewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReviewServlet</servlet-name>
        <url-pattern>/review</url-pattern>
    </servlet-mapping>

    <!-- 字符编码过滤器 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
</web-app>
